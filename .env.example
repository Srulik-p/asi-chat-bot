# OpenAI
OPENAI_API_KEY=sk-...REDACTED
OPENAI_MODEL=gpt-5

# Backend HTTP server (server.py)
# Shared secret required on the X-Webhook-Secret header for POST /auth/callback.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_CALLBACK_SECRET=replace-me

# Database — Postgres in prod, SQLite locally.
# Postgres (prod, e.g. Cloud SQL):
#   DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME
#   Cloud SQL via unix socket:
#   DATABASE_URL=postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
# Unset → SQLite at ./users.db (override with USERS_DB_PATH).
# DATABASE_URL=
# USERS_DB_PATH=users.db
