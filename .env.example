# ────────────────────────────────────────────────────────
# Backend (server.py — FastAPI / Cloud Run service "asi-chat-bot-api")
# ────────────────────────────────────────────────────────

# OpenAI — used by the LLM running inside the backend
OPENAI_API_KEY=sk-...REDACTED
OPENAI_MODEL=gpt-5

# External callback (POST /auth/callback). Shared with the sign-in service.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_CALLBACK_SECRET=replace-me-external

# Internal API (POST /chat/message, GET /chat/history, POST /chat/reset).
# Shared between the Streamlit UI and the backend. Different from the
# auth-callback secret so the chat surface isn't tied to an externally-shared key.
INTERNAL_API_SECRET=replace-me-internal

# Database — Postgres in prod, SQLite locally.
# Postgres:                DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME
# Cloud SQL (unix socket): DATABASE_URL=postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
# Unset → SQLite at ./users.db (override with USERS_DB_PATH).
# DATABASE_URL=
# USERS_DB_PATH=users.db

# ────────────────────────────────────────────────────────
# Streamlit UI (app.py — Cloud Run service "asi-chat-bot")
# ────────────────────────────────────────────────────────

# Backend base URL (no trailing slash).
CHAT_API_URL=http://localhost:8000

# Phone number prefilled in the test UI (override per-session via the sidebar).
DEFAULT_TEST_PHONE=0500000000

# --- Login link (account-status flow) ---
# Base of the external sign-in URL. The user's phone is appended as ?phoneNumber=...
LOGIN_URL_BASE=https://qa.sugardaddy.co.il/sign-in

# --- Outbound sender (push "I see you connected" after auth callback) ---
# Your site's messaging endpoint. POST body: {"phoneNumber": "...", "message": "..."}
OUTBOUND_SEND_URL=
OUTBOUND_SEND_SECRET=<paste here>
# Header used to carry OUTBOUND_SEND_SECRET (change if your endpoint expects a different one)
OUTBOUND_SEND_SECRET_HEADER=X-Internal-Secret
