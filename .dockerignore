# Local Python artifacts
.venv/
__pycache__/
*.pyc
*.pyo

# Secrets — must never enter the image
.env
.env.*
!.env.example

# Local SQLite store (user PII — phone numbers, tokens)
*.db
*.db-journal
*.db-wal
*.db-shm

# Project data (large + PII risk)
data/

# Dev-only files not needed at runtime
scripts/
tests/

# Build / OS / editor
.DS_Store
.git/
.gitignore
.claude/
.vscode/
.idea/

# Docker itself
Dockerfile
Dockerfile.server
.dockerignore
cloudbuild.server.yaml
