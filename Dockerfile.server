FROM python:3.11-slim

WORKDIR /app

# uv = fast Python package manager. Pinned minor for reproducibility.
COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /usr/local/bin/uv

# Install dependencies from the lockfile only.
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# API server runs the LLM, so it needs the assistant module, KB, and prompt.
COPY server.py db.py assistant.py kb.py system_prompt.md alembic.ini ./
COPY knowledge_base/ ./knowledge_base/
COPY alembic/ ./alembic/

ENV PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH"

# Cloud Run injects $PORT; fall back to 8080 for local docker run.
CMD uvicorn server:app --host 0.0.0.0 --port=${PORT:-8080}
