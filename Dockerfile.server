FROM python:3.11-slim

WORKDIR /app

# uv = fast Python package manager. Pinned minor for reproducibility.
# Must be able to read the lockfile revision written by the local uv (>=0.7).
COPY --from=ghcr.io/astral-sh/uv:0.7 /uv /usr/local/bin/uv

# Install dependencies from the lockfile only (cached layer; project installs below).
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# The package carries everything the API needs: code, system prompt, KB, migrations.
COPY src/ src/
RUN uv sync --frozen

ENV PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH"

# Cloud Run injects $PORT; fall back to 8080 for local docker run.
CMD uvicorn sugarbot.server:app --host 0.0.0.0 --port=${PORT:-8080}
